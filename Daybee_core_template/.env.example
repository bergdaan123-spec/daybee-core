# ─── App ──────────────────────────────────────────────────────────────────────
# Name shown in the sidebar, auth pages, and browser tab.
NEXT_PUBLIC_APP_NAME="MyApp"

# Short description shown in browser metadata.
# NEXT_PUBLIC_APP_DESCRIPTION="A SaaS application"

# ─── Database (e.g. Neon PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth / Auth.js (next-auth v5) ───────────────────────────────────────
# next-auth v5 uses AUTH_SECRET and AUTH_URL (not NEXTAUTH_* names).
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-character-string"
AUTH_URL="http://localhost:3000"

# Production (Vercel sets NEXTAUTH_URL automatically, but set AUTH_URL explicitly):
# AUTH_URL="https://your-app.vercel.app"

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set the authorised redirect URI to: https://your-domain.com/api/auth/callback/google
#
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── GitHub OAuth (optional) ──────────────────────────────────────────────────
# Create an OAuth app at https://github.com/settings/developers
# Set the callback URL to: https://your-domain.com/api/auth/callback/github
#
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
