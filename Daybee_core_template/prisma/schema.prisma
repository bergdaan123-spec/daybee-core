// ─── Prisma Schema — SaaS Boilerplate ────────────────────────────────────────
// This is the base schema. Add domain-specific models below the User model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────
// Core authentication + profile model.
// Extend with domain-specific relations as needed.

model User {
  id          String  @id @default(cuid())
  name        String
  email       String  @unique
  password    String

  // Profile / settings fields
  companyName String?
  phone       String?
  address     String?
  postalCode  String?
  city        String?
  logoUrl     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Add domain relations here ──────────────────────────────────────────────
  // Example:
  // entities Entity[]
}

// ─── Domain models ────────────────────────────────────────────────────────────
// Add your application-specific models below.
// Each model should include a `userId String` field and a relation to User.
